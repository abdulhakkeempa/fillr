{
  "manifest_version": 3,
  "name": "Code Placeholder Editor",
  "version": "1.0.0",
  "description": "Replace placeholders in code blocks with editable fields and copy the final command",
  "permissions": [
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}